{
  "name": "cc2node",
  "version": "1.1.1",
  "description": "Convert any Bun-compiled Claude Code release into a pure Node.js build that runs on plain Node 18+",
  "keywords": [
    "claude-code",
    "claude",
    "anthropic",
    "bun",
    "node",
    "compatibility",
    "extract",
    "transpile",
    "cli",
    "npm"
  ],
  "homepage": "https://github.com/cc-friend/cc2node#readme",
  "bugs": "https://github.com/cc-friend/cc2node/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cc-friend/cc2node.git"
  },
  "license": "MIT",
  "author": "Tom Chen (tomchen.org)",
  "bin": {
    "cc2node": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src test",
    "format": "biome format src test",
    "test": "tsx test/index.test.ts",
    "checkall": "npm run typecheck && npm run lint && npm run format && npm run test",
    "fixall": "biome check --write src test",
    "e2e": "tsx test/e2e.ts",
    "release:patch": "vbt patch",
    "release:minor": "vbt minor",
    "release:major": "vbt major",
    "prepublishOnly": "npm run build"
  },
  "vbt": {
    "push": true,
    "preBump": "npm run checkall",
    "postVerRepl": "npm install --package-lock-only --ignore-scripts",
    "commitFiles": [
      "package-lock.json"
    ]
  },
  "dependencies": {
    "unbunjs": "^1.0.0",
    "esbuild": "^0.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vbt": "^2.0.0"
  }
}
